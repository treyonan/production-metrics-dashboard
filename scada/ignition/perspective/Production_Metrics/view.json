{
  "custom": {
    "siteId": 101,
    "latestPayload": {}
  },
  "params": {},
  "propConfig": {
    "custom.latestPayload": {
      "binding": {
        "config": {
          "expression": "runScript(\"MES.Integrations.Production_Metrics.API.get_production_report_latest\", 30000, {view.custom.siteId})"
        },
        "type": "expr"
      }
    }
  },
  "props": {
    "defaultSize": {
      "width": 1280,
      "height": 720
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Title"
        },
        "position": {
          "x": 20,
          "y": 20,
          "width": 1240,
          "height": 40
        },
        "props": {
          "text": "Production Metrics -- Latest Reports",
          "style": {
            "fontSize": 20,
            "fontWeight": 600,
            "color": "#201F1E"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "SiteLabel"
        },
        "position": {
          "x": 20,
          "y": 70,
          "width": 80,
          "height": 32
        },
        "props": {
          "text": "site_id:",
          "style": {
            "fontSize": 13,
            "color": "#605E5C"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "SiteIdInput"
        },
        "position": {
          "x": 100,
          "y": 70,
          "width": 120,
          "height": 32
        },
        "props": {},
        "propConfig": {
          "props.value": {
            "binding": {
              "config": {
                "path": "view.custom.siteId"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.input.numeric-entry-field"
      },
      {
        "meta": {
          "name": "Hint"
        },
        "position": {
          "x": 240,
          "y": 70,
          "width": 1000,
          "height": 32
        },
        "props": {
          "text": "Auto-refreshes every 30 seconds. Edit site_id to switch sites.",
          "style": {
            "fontSize": 12,
            "color": "#605E5C",
            "fontStyle": "italic"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Status"
        },
        "position": {
          "x": 20,
          "y": 110,
          "width": 1240,
          "height": 28
        },
        "props": {
          "style": {
            "fontSize": 12,
            "color": "#605E5C"
          }
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.custom.latestPayload"
              },
              "transforms": [
                {
                  "code": "    if not value:\n        return ''\n    count = value.get('count', 0)\n    ts = value.get('generated_at', '')\n    return 'Workcenters reporting: %s   |   Generated at: %s' % (count, ts)\n",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "ProductionReportTable"
        },
        "position": {
          "x": 20,
          "y": 150,
          "width": 1240,
          "height": 540
        },
        "props": {},
        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "path": "view.custom.latestPayload"
              },
              "transforms": [
                {
                  "code": "    if not value:\n        return system.dataset.toDataSet([], [])\n    entries = value.get('entries', [])\n    if not entries:\n        return system.dataset.toDataSet([], [])\n    cols = ['id', 'prod_date', 'prod_id', 'site_id',\n            'department_id', 'department_name',\n            'shift', 'dtm',\n            'weather_conditions', 'avg_temp',\n            'avg_humidity', 'max_wind_speed', 'notes']\n    rows = []\n    for e in entries:\n        rows.append([e.get(c) for c in cols])\n    return system.dataset.toDataSet(cols, rows)\n",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "type": "ia.display.table"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.coord"
  }
}