{
  "custom": {
    "siteId": 101
  },
  "params": {},
  "props": {
    "defaultSize": {
      "width": 1280,
      "height": 720
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Title"
        },
        "position": {
          "x": 20,
          "y": 20,
          "width": 1240,
          "height": 40
        },
        "props": {
          "text": "Production Metrics -- Latest Reports",
          "style": {
            "fontSize": 20,
            "fontWeight": 600,
            "color": "#201F1E"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "SiteLabel"
        },
        "position": {
          "x": 20,
          "y": 70,
          "width": 80,
          "height": 32
        },
        "props": {
          "text": "site_id:",
          "style": {
            "fontSize": 13,
            "color": "#605E5C"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "SiteIdInput"
        },
        "position": {
          "x": 100,
          "y": 70,
          "width": 120,
          "height": 32
        },
        "props": {},
        "propConfig": {
          "props.value": {
            "binding": {
              "config": {
                "path": "view.custom.siteId"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.input.numeric-entry-field"
      },
      {
        "meta": {
          "name": "Hint"
        },
        "position": {
          "x": 240,
          "y": 70,
          "width": 1000,
          "height": 32
        },
        "props": {
          "text": "Auto-refreshes every 30 seconds. Edit site_id to switch sites.",
          "style": {
            "fontSize": 12,
            "color": "#605E5C",
            "fontStyle": "italic"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Status"
        },
        "position": {
          "x": 20,
          "y": 110,
          "width": 1240,
          "height": 28
        },
        "props": {
          "style": {
            "fontSize": 12,
            "color": "#605E5C"
          }
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "'Workcenters reporting: ' + toStr(runScript(\"MES.Integrations.Production_Metrics.API.get_production_report_latest\", 30, {view.custom.siteId})['count']) + '   |   Generated at: ' + toStr(runScript(\"MES.Integrations.Production_Metrics.API.get_production_report_latest\", 30, {view.custom.siteId})['generated_at'])"
              },
              "type": "expr"
            }
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "ProductionReportTable"
        },
        "position": {
          "x": 20,
          "y": 150,
          "width": 1240,
          "height": 540
        },
        "props": {},
        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "expression": "runScript(\"MES.Integrations.Production_Metrics.API.production_report_latest_dataset\", 30, {view.custom.siteId})"
              },
              "type": "expr"
            }
          }
        },
        "type": "ia.display.table"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.coord"
  }
}