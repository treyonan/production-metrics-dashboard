# =============================================================================
# Environment TEMPLATE -- placeholders only. DO NOT PUT REAL SECRETS HERE.
# =============================================================================
# This file is committed. Real values go in `.env` (gitignored).
# To use:
#   1. Copy this file:  Copy-Item .env.example .env
#   2. Fill real values into .env ONLY
#   3. If you ever find real secrets in .env.example, rotate them immediately.
#
# Variables prefixed PMD_ are consumed by pydantic-settings in
# app/core/config.py. Others (DB_CONN_STRING, FLOW_API_KEY) are consumed
# directly by source-specific integration code.
# =============================================================================

# ---- App-level (PMD_ prefix) --------------------------------------------

# Deployment identifier surfaced in /api/health (local / dev / staging / prod)
PMD_ENVIRONMENT=local

# structlog filtering level: DEBUG / INFO / WARNING / ERROR
PMD_LOG_LEVEL=INFO

# ---- SQL Server (Azure Managed SQL, ODBC 17) ----------------------------
# REQUIRED in production. SqlProductionReportSource is the only
# production-report source as of Phase 13. If unset, the SQL pool fails
# to initialize at startup and /api/production-report/* returns 503.
# Accepts either PMD_DB_CONN_STRING or DB_CONN_STRING (alias). Real
# value goes in .env, not here. NEVER commit real credentials.
# DB_CONN_STRING=Driver={ODBC Driver 17 for SQL Server};Server=<server.hostname>;Database=IA_ENTERPRISE;UID=<username>;PWD=<password>;Encrypt=yes;TrustServerCertificate=yes;

# ---- Snowflake -----------------------------------------------------------
# Consumed by the future Snowflake source. Not wired yet.
# NEVER commit real credentials.
# SNOWFLAKE_USER=<service-account-user>
# SNOWFLAKE_PASSWORD=<password>
# SNOWFLAKE_ACCOUNT=<account>.<region>.<provider>
# SNOWFLAKE_ROLE=<role>
# SNOWFLAKE_WAREHOUSE=<warehouse>
# SNOWFLAKE_DATABASE=<database>
# SNOWFLAKE_SCHEMA=<schema>

# ---- Flow REST API ------------------------------------------------------
# REQUIRED for /api/metrics/* (interval metrics) when the SQL backend
# has tag rows in [FLOW].[INTERVAL_METRIC_TAGS]. Without any Flow key
# the Flow client is not created and /api/metrics/* returns 503.
#
# Each Flow installation is independently administered and issues its
# own bearer token. The dashboard resolves the right key from the
# site_id of each request:
#
#   PMD_FLOW_API_KEY_<site_id>   per-site override (preferred)
#   PMD_FLOW_API_KEY             default fallback (used for any site
#                                without its own key set above)
#
# Single-site deployments can keep using just PMD_FLOW_API_KEY. Adding
# a new site whose Flow has a different token = add one more env var
# below AND a matching `flow_api_key_<id>` field in
# backend/app/core/config.py. See docs/adding-a-new-site.md.
#
# Both PMD_FLOW_API_KEY[_<id>] and FLOW_API_KEY[_<id>] aliases are
# accepted to ease migration from older env files.
# PMD_FLOW_API_KEY=<default-bearer-token>
# PMD_FLOW_API_KEY_101=<bcq-bearer-token>
# PMD_FLOW_API_KEY_100=<arq-bearer-token>

# ---- Timebase Historian i3X API (Phase 26) ------------------------------
# Each site's historian URL is NOT an env var -- every plant has its
# own historian on its own network. Per-site base_url lives in:
#
#   backend/app/integrations/timebase/catalog.yaml  (sites.<id>.base_url)
#
# To add a new site or change a historian URL, edit catalog.yaml and
# restart. No auth in Phase 1.
#
# Tuning knobs (uncomment to override defaults; apply to all sites):
# PMD_TIMEBASE_TIMEOUT_SECONDS=15
# PMD_TIMEBASE_CACHE_TTL_SECONDS=45
# PMD_TIMEBASE_CACHE_MAX_ENTRIES=128
